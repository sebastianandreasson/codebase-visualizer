{
  "name": "codebase-visualizer",
  "version": "0.2.1",
  "type": "module",
  "bin": {
    "codebase-visualizer": "./bin/codebase-visualizer.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build -c vite.standalone.config.ts && tsc -p tsconfig.build.json",
    "desktop": "npm run build && electron dist/desktop/main.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./planner": {
      "types": "./dist/planner/index.d.ts",
      "import": "./dist/planner.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./style.css": "./dist/style.css"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^36.3.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@mariozechner/pi-agent": "^0.9.0",
    "@persper/js-callgraph": "^1.3.2",
    "@xyflow/react": "^12.10.2",
    "ignore": "^7.0.5",
    "tree-sitter": "^0.22.4",
    "tree-sitter-rust": "^0.24.0",
    "typescript": "~6.0.2",
    "zustand": "^5.0.12"
  }
}
